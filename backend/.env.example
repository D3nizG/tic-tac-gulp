# Copy this to .env for local development. Never commit .env.

# Port the server listens on (Railway sets this automatically — do not override in Railway)
PORT=3001

# Allowed frontend origin for CORS and Socket.IO
# Local dev:
FRONTEND_ORIGIN=http://localhost:3000
# Production (set this in Railway dashboard):
# FRONTEND_ORIGIN=https://tic-tac-gulp.d3nizg.dev,http://localhost:3000

# Backend is served at: https://api.tic-tac-gulp.d3nizg.dev
