# Copy this to .env for local development. Never commit .env.

# Port the server listens on (Railway sets this automatically)
PORT=3001

# Allowed frontend origin for CORS and Socket.IO
FRONTEND_ORIGIN=http://localhost:3000

# Redis (optional — rooms persist across restarts when set)
# Get from Railway: Settings > Connect > REDIS_URL
REDIS_URL=

# Supabase (required for auth, match recording, friends, profiles)
# Get from: Supabase dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWT_SECRET=your-jwt-secret
