# Copy to .env.local for local development. Never commit .env.local.

# Backend Socket.IO / API URL
# Leave empty for local dev — Vite proxy handles routing to localhost:3001
VITE_SOCKET_URL=

# Supabase (required for auth, profiles, friends, invites)
# Get from: Supabase dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
