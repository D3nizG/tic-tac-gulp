{
  "name": "tic-tac-gulp",
  "private": true,
  "workspaces": ["shared", "backend", "frontend"],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "test": "npm run test -w shared",
    "build": "npm run build -w backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
